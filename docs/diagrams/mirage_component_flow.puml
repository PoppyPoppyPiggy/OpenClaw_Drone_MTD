}

' ═══ LAYER 4: CTI PIPELINE (GREEN) ═══
package "CTI Pipeline (Track B)" <<Rectangle>> #113311 {
    component [MavlinkInterceptor\nUDP :19551-53\npassive tap] as MI #226622
    component [AttackEventParser\nL0-L4 classification\nsession accumulator] as AEP #226622
    component [ATTCKMapper\n12 ICS TTPs\n4 protocols] as AM #226622
    component [STIXConverter\nSTIX 2.1 bundles\n7 object types] as SC #226622
    component [CTI Ingest API\nFastAPI :8765\n/ingest/event] as CIA #226622
}

package "Dataset Builder" <<Rectangle>> #113311 {
    component [PositiveCollector\nlabel=1\nhoneydrone source] as PC #226622
    component [NegativeGenerator\nlabel=0\nSITL/synthetic] as NG #226622
    component [DatasetPackager\nCSV + YAML\nSTIX bundles] as DP #226622
    component [DatasetValidator\nV1-V6 checks] as DV #226622
}

' ═══ LAYER 5: EVALUATION (PURPLE) ═══
package "Evaluation" <<Rectangle>> #221133 {
    component [MetricsCollector\nTable II-VI\nJSON output] as MC #442266
    component [DeceptionScorer\nDS = Σ(wi·ci)\n5 components] as DSC #442266
