# ════════════════════════════════════════════════════════════════
# MIRAGE-UAS Environment Variables
# 사용법: cp config/.env.example config/.env → 값 입력 후 실험 실행
#
# [규칙]
#   - 값이 빈 항목 = RL 옵티마이저 탐색 대상
#   - [Eq.XX]      = TIFS T-IFS-25285-2026 수식 번호
#   - [NEW]        = MIRAGE-UAS 신규 파라미터
# ════════════════════════════════════════════════════════════════

# ── [INFRA] 인프라 고정값 ──────────────────────────────────────
MAVLINK_PORT_BASE=14550
SITL_PORT_BASE=5760
WEBCLAW_PORT_BASE=18789
HTTP_PORT_BASE=8080
RTSP_PORT_BASE=8553
HONEY_DRONE_COUNT=3
CTI_API_PORT=8765
CTI_API_HOST=127.0.0.1
DOCKER_NETWORK_NAME=honey_isolated
DOCKER_IMAGE_DVD_CC=nicholasaleks/dvd-companion-computer:latest
DOCKER_IMAGE_DVD_FCU=nicholasaleks/dvd-flight-controller:latest
LOG_LEVEL=INFO
LOG_FORMAT=json
RESULTS_DIR=results

# ── [Eq.17] MTD Cost: C_mtd(a) = κ_ℓ · Σᵢ αᵢ · cost_i(a) ────
MTD_COST_SENSITIVITY_KAPPA=
MTD_ALPHA_WEIGHTS=
MTD_BREACH_PREVENTION_BETA=

# ── [Eq.18] Compromise: p_base · Π_i(1-e_i)^(1/n) ────────────
COMPROMISE_P_BASE=

# ── [Eq.19] DES: Σⱼ wⱼ · δⱼ(s) ──────────────────────────────
# 순서: [breach_rate, mttc_ratio, cost_ratio, deception_engagement]
DES_WEIGHT_LIST=

# ── [Eq.20] Redundancy ────────────────────────────────────────
REDUNDANCY_REWARD_HIGH=
REDUNDANCY_REWARD_LOW=
REDUNDANCY_THRESHOLD=

# ── [NEW] Deception Reward ────────────────────────────────────
# r_total = r_mtd + λ_d · r_dec
DECEPTION_LAMBDA=
# w_dwell + w_cmd + w_prot = 1.0
DECEPTION_WEIGHTS=
DECEPTION_DWELL_MAX_SEC=

# ── [NEW] Attacker Level Prior (합=1.0) ───────────────────────
ATTACKER_PRIORS=

# ── [RL] PPO Hyperparameters ──────────────────────────────────
PPO_LEARNING_RATE=
PPO_GAMMA=
PPO_CLIP_EPS=
PPO_ENTROPY_COEF=
PPO_N_STEPS=2048
PPO_BATCH_SIZE=64
CURRICULUM_PHASE=1

# ── 세션 관리 ─────────────────────────────────────────────────
SESSION_TIMEOUT_SEC=60
SESSION_CLEANUP_INTERVAL_SEC=30
ENGAGEMENT_URGENCY_L1_THRESHOLD=10
ENGAGEMENT_URGENCY_L2_THRESHOLD=30
ENGAGEMENT_URGENCY_L3_THRESHOLD=60
ENGAGEMENT_EXPLOIT_THRESHOLD=1

# ── [NEW] OpenClaw Agent ──────────────────────────────────────
# 자율 proactive 행동 실행 주기 (초)
AGENT_PROACTIVE_INTERVAL_SEC=
# MAVLink sysid 자율 변경 주기 (초)
AGENT_SYSID_ROTATION_SEC=
# WebSocket 포트 자율 변경 주기 (초)
AGENT_PORT_ROTATION_SEC=
# false flag 트리거 체류 시간 임계값 (초)
AGENT_FALSE_FLAG_DWELL_THRESHOLD=
# service mirror 트리거 서비스 접촉 수 임계값
AGENT_MIRROR_SERVICE_THRESHOLD=

# ── [NEW] DeceptionScore Weights ──────────────────────────────
# DS = w1*(time_on_decoys/total) + w2*(1-breach_rate) + w3*confusion
#    + w4*(breadcrumb_follow) + w5*(ghost_hit)
# w1+w2+w3+w4+w5 = 1.0
DECEPTION_SCORE_WEIGHTS=

# ── [PCAP] Packet Capture ─────────────────────────────────────
PCAP_ENABLED=false

# ── [OMNETPP] Reproducibility ─────────────────────────────────
OMNETPP_EXPORT_ENABLED=false
OMNETPP_TRACE_DIR=omnetpp_trace
REPRO_PACK_ENABLED=false
ATTACKER_LEVEL_DURATION_SEC=60
